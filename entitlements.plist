<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ============================================================ -->
	<!-- 无忧辅助 - TrollStore 核心权限 (精简版) -->
	<!-- ============================================================ -->
	<!-- 为什么精简？
	     170 行的旧 plist 包含大量无效 key（TCC、钥匙串、蓝牙、WiFi 等），
	     ldid 做 DER 编码时可能因这些不存在的 key 而失败，导致系统
	     读取不到 task_for_pid-allow，TrollStore 只能显示 "mobile 用户"。
	     只保留 iOS 真实存在且本应用必需的 key。
	-->

	<!-- 关闭沙盒 (TrollStore 非沙盒运行) -->
	<key>com.apple.private.security.no-sandbox</key>
	<true/>
	<key>com.apple.private.security.no-container</key>
	<true/>

	<!-- TrollStore 基础开锁 -->
	<key>platform-application</key>
	<true/>
	<key>get-task-allow</key>
	<true/>
	<key>dynamic-codesigning</key>
	<true/>

	<!-- root 提权 (task_for_pid(0) → kernel_task) -->
	<key>task_for_pid-allow</key>
	<true/>
	<key>com.apple.system-task-ports</key>
	<true/>

	<!-- 重启/关机等系统操作 -->
	<key>com.apple.private.security.system-actions</key>
	<true/>

	<!-- 跳过代码签名库验证 (允许加载任意 dylib) -->
	<key>com.apple.private.skip-library-validation</key>
	<true/>
</dict>
</plist>
